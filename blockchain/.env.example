# 🔐 PROYECTO INFINITO — Blockchain Config
# =========================================
# Copia este archivo a .env y completa los valores

# Tu wallet PRIVATE_KEY (NUNCA compartir, NUNCA subir a git)
# Para Polygon Amoy Testnet — usa una wallet dedicada para tests
PRIVATE_KEY=0xtu_private_key_aqui

# RPC URL de Polygon Amoy (default: https://rpc-amoy.polygon.technology)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# API Key de Polygonscan para verificar el contrato (opcional)
POLYGONSCAN_API_KEY=tu_api_key_aqui

# Direcciones del contrato después del deploy
TI_TOKEN_ADDRESS=0x...completar_despues_deploy

# Direcciones de los beneficiarios
PADRES_ADDRESS=0x...wallet_padres
JOKER_ADDRESS=0x...wallet_joker
TREASURY_ADDRESS=0x...wallet_tesoreria
